<%- include('partials/header') %>

<div class="centered" style="padding: 60px 20px;">
  <div class="jumbotron" style="max-width: 800px;">
    <i class="fas fa-lock-open" style="color: #10b981; font-size: 4rem; margin-bottom: 30px;"></i>
    <h1>You've Discovered A Secret!</h1>
    <p class="lead" style="color: #475569; margin: 20px 0 35px 0;">Someone trusted you with their hidden thought</p>
    
    <!-- Secret Content Card -->
    <div style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border: 2px solid #0ea5e9; border-radius: 16px; padding: 35px; margin: 40px 0; position: relative; overflow: hidden;">
      <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: radial-gradient(circle at 30% 50%, rgba(37, 99, 235, 0.05) 0%, transparent 70%); pointer-events: none;"></div>
      <p class="secret-text" style="background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%); margin: 0; padding: 25px; border-radius: 12px; font-size: 1.5rem; position: relative; z-index: 2;">
        Jack Bauer is my hero.
      </p>
    </div>

    <p class="lead" style="color: #64748b; font-size: 1rem; margin-top: 35px;">
      <i class="fas fa-heart" style="color: #ef4444;"></i> 
      It took courage to share. Thank you for keeping this sacred.
    </p>

    <hr style="margin: 40px 0;">

    <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
      <a class="btn btn-light" href="/register" role="button">Share Your Own Secret</a>
      <a class="btn btn-dark" href="/" role="button">Back to Home</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>