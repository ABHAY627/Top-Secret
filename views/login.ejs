<%- include('partials/header') %>

<div class="container">
  <div class="card">
    <!-- Header Section -->
    <div class="card-header">
      <h1>Welcome Back</h1>
      <p>Sign in to your account and access your secrets securely</p>
    </div>

    <!-- Form Section -->
    <div class="card-body">
      <form action="/login" method="POST" id="loginForm">
        
        <!-- Email Field -->
        <div class="form-group">
          <label for="email" class="form-label">Email Address</label>
          <div class="form-group-wrapper">
            <i class="fas fa-envelope form-group-icon"></i>
            <input 
              type="email" 
              id="email"
              class="form-control" 
              name="username" 
              placeholder="your.email@example.com"
              required
              autocomplete="email"
            >
          </div>
          <small class="helper-text" style="display:none;" id="emailHelper">
            <i class="fas fa-check-circle"></i> Valid email
          </small>
        </div>

        <!-- Password Field -->
        <div class="form-group">
          <label for="password" class="form-label">Password</label>
          <div class="form-group-wrapper">
            <i class="fas fa-lock form-group-icon"></i>
            <input 
              type="password" 
              id="password"
              class="form-control" 
              name="password" 
              placeholder="Enter your password"
              required
              autocomplete="current-password"
            >
          </div>
          <small class="helper-text text-muted" style="margin-top: 8px;">
            <i class="fas fa-info-circle"></i> Never share your password
          </small>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-dark" role="button">
          <span class="button-text">Sign In</span>
          <i class="fas fa-spinner loading" style="display:none; margin-left: 8px;"></i>
        </button>

      </form>

      <!-- Auth Link Section -->
      <div class="auth-link">
        <p>Don't have an account? <a href="/register">Create one now</a></p>
      </div>
    </div>
  </div>
</div>

<script>
// Email validation
document.getElementById('email').addEventListener('blur', function() {
  const emailHelper = document.getElementById('emailHelper');
  if (this.value && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.value)) {
    emailHelper.style.display = 'flex';
  } else {
    emailHelper.style.display = 'none';
  }
});

// Form submission with loading state
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = this.querySelector('.btn-dark');
  const spinner = btn.querySelector('.loading');
  const text = btn.querySelector('.button-text');
  btn.disabled = true;
  spinner.style.display = 'inline-block';
});
</script>

<%- include('partials/footer') %>
